<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="/css/styleregistro.css">

    <title>Login</title>
</head>

<body>
    <%- include('../partials/headerlog') %>
        <main>
            <form id="formularioRegistro" class="todo" action="" method="POST">
                <div class="registro-todo">
                    <div class="registro">
                        <h1 class="registrate">¡Registrate!</h1>
                        <input required type="email" id="email" class="registro" placeholder="Tu email">
                    </div>
                    <div class="registro">
                        <input required type="password" id="password" class="registro"
                            placeholder="Tu nueva contraseña">
                    </div>
                    <div class="registro">
                        <input required type="password" id="password2" class="registro"
                            placeholder="Repite tu contraseña">

                    </div>
                    <div class="registro">
                        <button class="boton" type="submit">Crear cuenta</button>
                    </div>
                </div>
                <p>¿Ya tienes una cuenta?<a href="/">Inicia sesion</a></p>
            </form>
        </main>

        <%- include('../partials/footer') %>

            <script src="/js/validacionesRegistro.js"></script>
</body>

</html>